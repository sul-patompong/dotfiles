#!/bin/bash

PLUGIN_DIR="$CONFIG_DIR/plugins"

# в”Ђв”Ђ Colors (Gruvbox Dark, 0xAARRGGBB) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
BAR_COLOR=0xff1d2021
ITEM_BG=0xff3c3836
ACCENT=0xffd79921
WHITE=0xffebdbb2
GREY=0xff928374
ORANGE=0xffff8019
TRANSPARENT=0x00000000

# в”Ђв”Ђ Bar appearance в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
sketchybar --bar \
  position=top \
  height=36 \
  blur_radius=30 \
  color=$BAR_COLOR \
  border_width=0 \
  margin=0 \
  y_offset=0 \
  padding_left=8 \
  padding_right=8 \
  topmost=window

# в”Ђв”Ђ Default item styling в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
sketchybar --default \
  icon.font="IosevkaTerm Nerd Font:Bold:14.0" \
  icon.color=$WHITE \
  label.font="IosevkaTerm Nerd Font:Regular:14.0" \
  label.color=$WHITE \
  background.color=$ITEM_BG \
  background.corner_radius=6 \
  background.height=26 \
  padding_left=4 \
  padding_right=4 \
  label.padding_left=6 \
  label.padding_right=6 \
  icon.padding_left=8 \
  icon.padding_right=4

# в”Ђв”Ђ Left: AeroSpace workspaces в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
sketchybar --add event aerospace_workspace_change

WORKSPACES=("u" "i" "o" "p" "7" "8" "9" "0")
ICONS=("у°ЉЇ" "у°ЌЎ" "у°…©" "у°ѓ®" "у°Ћ¶" "у°Ћ№" "у°Ћј" "у°ЋЎ")

for i in "${!WORKSPACES[@]}"; do
  ws="${WORKSPACES[$i]}"
  icon="${ICONS[$i]}"
  sketchybar --add item "workspace.$ws" left \
    --set "workspace.$ws" \
      icon="$icon" \
      icon.font="IosevkaTerm Nerd Font:Bold:16.0" \
      icon.color=$GREY \
      label.drawing=off \
      background.color=$TRANSPARENT \
      background.height=26 \
      background.corner_radius=6 \
      padding_left=2 \
      padding_right=2 \
      icon.padding_left=8 \
      icon.padding_right=8 \
      click_script="aerospace workspace $ws" \
      script="$PLUGIN_DIR/workspace.sh $ws"
done

for ws in "${WORKSPACES[@]}"; do
  sketchybar --subscribe "workspace.$ws" aerospace_workspace_change
done

# в”Ђв”Ђ Center-left: Front app (left of notch) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
sketchybar --add item front_app q \
  --set front_app \
    icon.drawing=off \
    label.font="VictorMono Nerd Font:SemiBold:14.0" \
    label.color=$WHITE \
    background.color=$TRANSPARENT \
    label.padding_right=20 \
    script="$PLUGIN_DIR/front_app.sh" \
  --subscribe front_app front_app_switched

# в”Ђв”Ђ Center-right: Clock (right of notch) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
sketchybar --add item clock e \
  --set clock \
    icon.drawing=off \
    label.font="VictorMono Nerd Font:SemiBold:14.0" \
    label.color=$WHITE \
    background.color=$TRANSPARENT \
    label.padding_left=20 \
    script="$PLUGIN_DIR/clock.sh" \
    update_freq=30

# в”Ђв”Ђ Right: Battery в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
sketchybar --add item battery right \
  --set battery \
    icon.font="IosevkaTerm Nerd Font:Regular:16.0" \
    label.font="IosevkaTerm Nerd Font:Regular:13.0" \
    background.color=$ITEM_BG \
    script="$PLUGIN_DIR/battery.sh" \
    update_freq=120 \
  --subscribe battery system_woke power_source_change

# в”Ђв”Ђ Right: WiFi / Ethernet в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
sketchybar --add item wifi right \
  --set wifi \
    icon.font="IosevkaTerm Nerd Font:Regular:16.0" \
    label.font="IosevkaTerm Nerd Font:Regular:13.0" \
    background.color=$ITEM_BG \
    script="$PLUGIN_DIR/wifi.sh" \
    update_freq=10 \
  --subscribe wifi wifi_change system_woke


# в”Ђв”Ђ Fullscreen indicator (hidden by default) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
sketchybar --add item fullscreen_indicator center \
  --set fullscreen_indicator \
    drawing=off \
    icon.drawing=off \
    label.drawing=off \
    background.color=0xffcc241d \
    background.height=3 \
    background.corner_radius=0 \
    width=4000 \
    y_offset=-16 \
    padding_left=0 \
    padding_right=0

# в”Ђв”Ђ Force initial update в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
sketchybar --update
