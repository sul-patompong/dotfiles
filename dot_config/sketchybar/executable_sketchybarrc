#!/bin/bash

CONFIG_DIR="$HOME/.config/sketchybar"
PLUGIN_DIR="$CONFIG_DIR/plugins"
ITEM_DIR="$CONFIG_DIR/items"

source "$CONFIG_DIR/colors.sh"
source "$CONFIG_DIR/icons.sh"

# ── Keyboard layout helpers (Swift, built once) ───────────────────────────
KB_LAYOUT_BIN="$HOME/.local/bin/keyboard-layout"
KB_LISTENER_BIN="$HOME/.local/bin/keyboard-layout-listener"

if [ ! -x "$KB_LAYOUT_BIN" ]; then
  mkdir -p "$HOME/.local/bin"
  cat > /tmp/keyboard_layout.swift << 'SWIFT'
import Carbon
if let src = TISCopyCurrentKeyboardInputSource()?.takeRetainedValue(),
   let ptr = TISGetInputSourceProperty(src, kTISPropertyInputSourceID) {
    print(Unmanaged<CFString>.fromOpaque(ptr).takeUnretainedValue() as String)
}
SWIFT
  swiftc /tmp/keyboard_layout.swift -o "$KB_LAYOUT_BIN" 2>/dev/null
  rm -f /tmp/keyboard_layout.swift
fi

if [ ! -x "$KB_LISTENER_BIN" ]; then
  cat > /tmp/keyboard_listener.swift << 'SWIFT'
import Carbon
import Foundation

DistributedNotificationCenter.default().addObserver(
    forName: NSNotification.Name(kTISNotifySelectedKeyboardInputSourceChanged as String),
    object: nil, queue: nil) { _ in
    let p = Process()
    p.launchPath = "/bin/sh"
    p.arguments = ["-c", "sketchybar --trigger keyboard_change"]
    try? p.run()
}
RunLoop.main.run()
SWIFT
  swiftc /tmp/keyboard_listener.swift -o "$KB_LISTENER_BIN" 2>/dev/null
  rm -f /tmp/keyboard_listener.swift
fi

pkill -f "$KB_LISTENER_BIN" 2>/dev/null
"$KB_LISTENER_BIN" >/dev/null 2>&1 &
disown

# ── Bar appearance (transparent bg — pills float against wallpaper) ────────
sketchybar --bar \
  position=top \
  height=46 \
  blur_radius=0 \
  color="$TRANSPARENT" \
  border_width=0 \
  margin=0 \
  y_offset=0 \
  corner_radius=0 \
  padding_left=12 \
  padding_right=12 \
  notch_width=210 \
  notch_display_height=32 \
  topmost=on \
  show_in_fullscreen=on

# ── Default item styling ───────────────────────────────────────────────────
sketchybar --default \
  icon.font="JetBrainsMono Nerd Font:Bold:17.0" \
  icon.color="$WHITE" \
  label.font="JetBrainsMono Nerd Font:Regular:14.0" \
  label.color="$WHITE" \
  background.color="$ITEM_BG" \
  background.corner_radius=8 \
  background.height=30 \
  padding_left=4 \
  padding_right=4 \
  label.padding_left=6 \
  label.padding_right=6 \
  icon.padding_left=8 \
  icon.padding_right=4

# ── Items ──────────────────────────────────────────────────────────────────
# Note: right-side items populate from the right edge moving leftward,
# so order of addition is REVERSE of visual left-to-right layout.
source "$ITEM_DIR/aerospace.sh"
source "$ITEM_DIR/front_app.sh"
source "$ITEM_DIR/clock.sh"
# Right side (rightmost first): cpu, battery, wifi, volume, keyboard, media
source "$ITEM_DIR/cpu.sh"
source "$ITEM_DIR/battery.sh"
source "$ITEM_DIR/wifi.sh"
source "$ITEM_DIR/volume.sh"
source "$ITEM_DIR/keyboard.sh"
source "$ITEM_DIR/media.sh"

# (No system bracket — each item has its own pill)

# ── Force initial update ───────────────────────────────────────────────────
sketchybar --update
sketchybar --trigger aerospace_fullscreen_change
sketchybar --trigger aerospace_workspace_change
