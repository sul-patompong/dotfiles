{
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Bash(ls:*)",
      "Bash(ls)",
      "Bash(grep:*)",
      "Bash(grep)"
    ]
  },
  "model": "opus[1m]",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // .tool_response.filePath' | { read -r f; case \"$f\" in *.md|*.markdown) npx --yes markdownlint-cli2 --fix \"$f\" ;; esac } 2>/dev/null || true"
          }
        ]
      }
    ]
  },
  "theme": "auto",
  "statusLine": {
    "type": "command",
    "command": "$HOME/.claude/statusline.sh"
  }
}
